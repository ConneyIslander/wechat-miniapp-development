/**app.wxss**/
page {
  --primary: #667EEA;
  --danger: #F43F5E;
  --success: #10B981;
  --text: #1F2937;
  --muted: #9CA3AF;
  --bg: #F0F2F5;
  --white: #FFFFFF;

  background-color: var(--bg);
  color: var(--text);
  font-size: 28rpx;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
}

view, text {
  box-sizing: border-box;
}

.page-container {
  padding: 24rpx;
  min-height: 100vh;
}

.placeholder-block {
  background-color: var(--white);
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 2rpx dashed var(--muted);
}