/* components/category-picker/category-picker.wxss */

.category-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 8rpx 0;
}

.category-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 0;
  border-radius: 16rpx;
  transition: all 0.2s;
}

.category-item.active .category-icon {
  background: linear-gradient(135deg, #667EEA, #764BA2);
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.4);
  transform: scale(1.1);
}

.category-item.active .category-name {
  color: #667EEA;
  font-weight: 600;
}

.category-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #E8EAF6, #EDE7F6);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-bottom: 8rpx;
  transition: all 0.2s;
}

.category-name {
  font-size: 22rpx;
  color: var(--text);
  transition: color 0.2s;
}
