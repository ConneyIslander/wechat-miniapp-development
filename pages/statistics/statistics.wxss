/* pages/statistics/statistics.wxss */
.page {
  min-height: 100vh;
  background: #f5f6fa;
  padding-bottom: 40rpx;
}

/* ---- 收支汇总 ---- */
.summary-row {
  background: #fff;
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  margin: 16rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.summary-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.summary-label {
  font-size: 24rpx;
  color: #888;
  margin-bottom: 8rpx;
}

.summary-value {
  font-size: 32rpx;
  font-weight: 600;
}

.summary-value.expense { color: #e74c3c; }
.summary-value.income { color: #2ecc71; }

.summary-divider {
  width: 1rpx;
  height: 60rpx;
  background: #eee;
}

/* ---- 图表区 ---- */
.chart-section {
  background: #fff;
  margin: 16rpx;
  border-radius: 16rpx;
  padding: 24rpx 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.chart-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

.canvas-wrap {
  width: 100%;
  height: 360rpx;
}

.bar-wrap {
  height: 400rpx;
}

.chart-canvas {
  width: 100%;
  height: 100%;
}

/* ---- 饼图图例 ---- */
.legend {
  display: flex;
  flex-wrap: wrap;
  margin-top: 16rpx;
  padding: 0 8rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  width: 50%;
  padding: 8rpx 0;
}

.legend-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  margin-right: 10rpx;
  flex-shrink: 0;
}

.legend-name {
  font-size: 24rpx;
  color: #555;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.legend-value {
  font-size: 24rpx;
  color: #333;
  font-weight: 500;
  margin: 0 8rpx;
}

.legend-pct {
  font-size: 22rpx;
  color: #aaa;
  width: 60rpx;
  text-align: right;
}

.empty-chart {
  text-align: center;
  padding: 60rpx 0;
  color: #aaa;
  font-size: 26rpx;
}
