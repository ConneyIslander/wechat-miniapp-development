/* pages/settings/settings.wxss */
.page {
  min-height: 100vh;
  background: #f5f6fa;
  padding: 16rpx;
  padding-bottom: 40rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

/* 预算区 */
.budget-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
}

.budget-amount {
  display: flex;
  align-items: baseline;
}

.budget-num {
  font-size: 56rpx;
  font-weight: 700;
  color: #1890ff;
}

.budget-unit {
  font-size: 28rpx;
  color: #999;
  margin-left: 6rpx;
}

.budget-tip {
  font-size: 24rpx;
  color: #bbb;
  padding: 6rpx 16rpx;
  background: #f5f5f5;
  border-radius: 20rpx;
}

.budget-status {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 12rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.status-expense {
  font-size: 26rpx;
  color: #e74c3c;
  font-weight: 600;
}

.status-safe {
  font-size: 26rpx;
  color: #2ecc71;
  font-weight: 600;
}

.status-remaining {
  font-size: 24rpx;
  color: #999;
}

/* Tab */
.tab-bar {
  display: flex;
  background: #f5f6fa;
  border-radius: 10rpx;
  padding: 4rpx;
  margin-bottom: 20rpx;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 12rpx 0;
  font-size: 28rpx;
  color: #888;
  border-radius: 8rpx;
  transition: all 0.2s;
}

.tab.active {
  background: #fff;
  color: #1890ff;
  font-weight: 600;
  box-shadow: 0 2rpx 6rpx rgba(24, 144, 255, 0.15);
}

/* 分类列表 */
.category-list {
  min-height: 80rpx;
}

.cat-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.cat-item:last-child {
  border-bottom: none;
}

.cat-icon {
  font-size: 40rpx;
  width: 60rpx;
  text-align: center;
}

.cat-name {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  margin-left: 16rpx;
}

.cat-lock {
  font-size: 24rpx;
  padding: 4rpx 10rpx;
  color: #bbb;
}

.cat-del {
  font-size: 26rpx;
  color: #ff4d4f;
  padding: 4rpx 12rpx;
}

.empty-cat {
  text-align: center;
  padding: 40rpx;
  color: #bbb;
  font-size: 26rpx;
}

/* 添加按钮 */
.add-cat-btn {
  text-align: center;
  padding: 20rpx;
  color: #1890ff;
  font-size: 28rpx;
  border-top: 1rpx dashed #e8e8e8;
  margin-top: 8rpx;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-box {
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx 32rpx;
  width: 600rpx;
  max-width: 80vw;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  text-align: center;
  margin-bottom: 32rpx;
}

.modal-input {
  border: 1rpx solid #ddd;
  border-radius: 10rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  margin-bottom: 24rpx;
}

.modal-input.small {
  flex: 1;
}

.modal-field {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.field-label {
  font-size: 28rpx;
  color: #666;
  width: 60rpx;
  flex-shrink: 0;
}

.modal-btns {
  display: flex;
  gap: 20rpx;
  margin-top: 8rpx;
}

.btn-cancel,
.btn-confirm {
  flex: 1;
  font-size: 28rpx;
  border-radius: 10rpx;
  padding: 16rpx 0;
  margin: 0;
  line-height: 1.6;
}

.btn-cancel {
  background: #f5f5f5;
  color: #666;
}

.btn-confirm {
  background: #1890ff;
  color: #fff;
}
