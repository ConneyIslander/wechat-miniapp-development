<!--pages/index/index.wxml-->
<view class="page">

  <!-- 月份切换 -->
  <view class="month-bar">
    <view class="month-arrow" bindtap="onPrevMonth">‹</view>
    <view class="month-text">{{month}}年</view>
    <view class="month-arrow" bindtap="onNextMonth">›</view>
  </view>

  <!-- 概览卡片 -->
  <view class="overview-card">
    <view class="overview-row">
      <view class="overview-item">
        <view class="overview-label">本月支出</view>
        <view class="overview-value expense">¥{{totalExpense}}</view>
      </view>
      <view class="overview-divider"></view>
      <view class="overview-item">
        <view class="overview-label">本月收入</view>
        <view class="overview-value income">¥{{totalIncome}}</view>
      </view>
      <view class="overview-divider"></view>
      <view class="overview-item">
        <view class="overview-label">结余</view>
        <view class="overview-value">¥{{balance}}</view>
      </view>
    </view>
  </view>

  <!-- 今日账单 -->
  <view class="section-title">今日账单</view>
  <view class="bill-list">
    <block wx:if="{{todayBills.length === 0}}">
      <view class="empty-tip">今天还没有记账</view>
    </block>
    <block wx:else>
      <view
        wx:for="{{todayBills}}"
        wx:key="id"
        class="bill-item"
      >
        <view class="bill-icon-wrap {{item.iconBg}}">
          <text class="bill-icon-text">{{item.iconChar}}</text>
        </view>
        <view class="bill-info">
          <view class="bill-name">{{item.category}}</view>
          <view class="bill-note">{{item.note}}</view>
        </view>
        <view class="bill-amount {{item.type}}">
          {{item.type === 'income' ? '+' : '-'}}{{item.amount}}
        </view>
      </view>
    </block>
  </view>

  <!-- FAB -->
  <view class="fab" bindtap="onAddTap">+</view>

</view>
