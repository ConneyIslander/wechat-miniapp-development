<!--pages/index/index.wxml-->
<view class="page">

  <!-- 月份切换 -->
  <view class="month-bar">
    <view class="month-arrow" bindtap="onPrevMonth">‹</view>
    <view class="month-text">{{month}}年</view>
    <view class="month-arrow" bindtap="onNextMonth">›</view>
  </view>

  <!-- 概览卡片 -->
  <view class="overview-card">
    <view class="overview-row">
      <view class="overview-item">
        <view class="overview-label">本月支出</view>
        <view class="overview-value expense">¥{{totalExpense}}</view>
      </view>
      <view class="overview-divider"></view>
      <view class="overview-item">
        <view class="overview-label">本月收入</view>
        <view class="overview-value income">¥{{totalIncome}}</view>
      </view>
      <view class="overview-divider"></view>
      <view class="overview-item">
        <view class="overview-label">结余</view>
        <view class="overview-value">¥{{balance}}</view>
      </view>
    </view>
  </view>

  <!-- 本月账单（按日期分组） -->
  <view class="section-title">本月账单</view>
  <view class="bill-list">
    <block wx:if="{{groupedBills.length === 0}}">
      <view class="empty-tip">本月还没有账单</view>
    </block>
    <block wx:else>
      <view
        wx:for="{{groupedBills}}"
        wx:key="date"
        class="day-group"
      >
        <!-- 日期标题 -->
        <view class="day-header">
          <text class="day-date">{{item.date}}</text>
          <text class="day-summary expense">支 ¥{{item.expense}}</text>
          <text class="day-summary income">收 ¥{{item.income}}</text>
        </view>
        <!-- 该日账单 -->
        <view
          wx:for="{{item.bills}}"
          wx:for-item="bill"
          wx:key="id"
          class="bill-item"
        >
          <view class="bill-icon-wrap {{bill.iconBg}}">
            <text class="bill-icon-text">{{bill.iconChar}}</text>
          </view>
          <view class="bill-info">
            <view class="bill-name">{{bill.category}}</view>
            <view class="bill-note">{{bill.note}}</view>
          </view>
          <view class="bill-amount {{bill.type}}">
            {{bill.type === 'income' ? '+' : '-'}}{{bill.amount}}
          </view>
        </view>
      </view>
    </block>
  </view>

  <!-- FAB -->
  <view class="fab" bindtap="onAddTap">+</view>

</view>
