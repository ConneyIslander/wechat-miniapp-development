<!--pages/index/index.wxml-->
<view class="page-container">
  <view class="placeholder-block">
    <text>【顶部】月度概览区域</text>
    <view>月份：{{month}}</view>
    <view>本月支出：¥{{totalExpense}}</view>
    <view>本月收入：¥{{totalIncome}}</view>
    <view>结余：¥{{balance}}</view>
  </view>

  <view class="placeholder-block">
    <text>【中部】今日账单列表</text>
    <block wx:if="{{todayBills.length === 0}}">
      <view>暂无账单</view>
    </block>
  </view>

  <view class="placeholder-block">
    <text>【底部】+ 按钮（FAB）</text>
    <button bindtap="onAddTap">记一笔</button>
  </view>
</view>