<!--pages/add-bill/add-bill.wxml-->
<view class="page">

  <!-- 类型切换 -->
  <view class="type-tabs">
    <view
      class="type-tab {{type === 'expense' ? 'active' : ''}}"
      bindtap="onTypeChange"
      data-type="expense"
    >支出</view>
    <view
      class="type-tab {{type === 'income' ? 'active' : ''}}"
      bindtap="onTypeChange"
      data-type="income"
    >收入</view>
  </view>

  <!-- 金额输入 -->
  <view class="amount-section">
    <text class="amount-prefix">¥</text>
    <input
      class="amount-input"
      type="digit"
      placeholder="0.00"
      placeholder-class="amount-placeholder"
      value="{{amount}}"
      bindinput="onAmountInput"
      focus="{{amountFocus}}"
    />
  </view>

  <!-- 分类选择 -->
  <view class="section">
    <view class="section-title">选择分类</view>
    <category-picker
      categories="{{currentCategories}}"
      selectedId="{{selectedCategoryId}}"
      bind:change="onCategoryChange"
    />
  </view>

  <!-- 日期 & 备注 -->
  <view class="section">
    <view class="form-row">
      <text class="form-label">日期</text>
      <picker mode="date" value="{{date}}" bindchange="onDateChange">
        <view class="form-value">{{date}}</view>
      </picker>
    </view>
    <view class="form-row">
      <text class="form-label">备注</text>
      <input
        class="form-input"
        placeholder="选填"
        value="{{note}}"
        bindinput="onNoteInput"
      />
    </view>
  </view>

  <!-- 提交 -->
  <view class="submit-section">
    <button class="submit-btn" bindtap="onSubmit">确认记账</button>
  </view>

</view>
