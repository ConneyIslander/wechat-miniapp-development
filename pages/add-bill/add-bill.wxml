<!--pages/add-bill/add-bill.wxml-->
<view class="page-container">
  <view class="placeholder-block">
    <text>【顶部】类型切换（支出/收入）</text>
    <view>当前类型：{{type}}</view>
  </view>

  <view class="placeholder-block">
    <text>【中部】金额输入</text>
    <view>金额：{{amount || '未填'}}</view>
  </view>

  <view class="placeholder-block">
    <text>【中部】分类选择</text>
    <view>已选分类ID：{{categoryId || '未选'}}</view>
  </view>

  <view class="placeholder-block">
    <text>【中部】日期选择</text>
    <view>日期：{{date}}</view>
  </view>

  <view class="placeholder-block">
    <text>【中部】备注</text>
    <view>备注：{{note || '无'}}</view>
  </view>

  <view class="placeholder-block">
    <text>【底部】提交按钮</text>
    <button type="primary">保存</button>
  </view>
</view>