/* pages/add-bill/add-bill.wxss */

.page {
  min-height: 100vh;
  background: var(--bg);
  padding: 24rpx;
  padding-bottom: 160rpx;
}

/* 类型切换 */
.type-tabs {
  display: flex;
  background: var(--white);
  border-radius: 16rpx;
  padding: 8rpx;
  margin-bottom: 24rpx;
}
.type-tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 12rpx;
  font-size: 30rpx;
  color: var(--muted);
  transition: all 0.2s;
}
.type-tab.active {
  background: linear-gradient(135deg, #667EEA, #764BA2);
  color: #FFFFFF;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.4);
}

/* 金额 */
.amount-section {
  display: flex;
  align-items: center;
  background: var(--white);
  border-radius: 20rpx;
  padding: 40rpx 32rpx;
  margin-bottom: 24rpx;
}
.amount-prefix {
  font-size: 56rpx;
  font-weight: 700;
  color: var(--text);
  margin-right: 8rpx;
}
.amount-input {
  flex: 1;
  font-size: 72rpx;
  font-weight: 700;
  color: var(--text);
  min-height: 72rpx;
}
.amount-placeholder {
  font-size: 72rpx;
  font-weight: 700;
  color: #D1D5DB;
}

/* 通用 section */
.section {
  background: var(--white);
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 24rpx;
}
.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 16rpx;
}

/* 表单行 */
.form-row {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}
.form-row:last-child {
  border-bottom: none;
  padding-bottom: 0;
}
.form-label {
  font-size: 30rpx;
  color: var(--text);
  width: 80rpx;
  flex-shrink: 0;
}
.form-value {
  flex: 1;
  font-size: 30rpx;
  color: var(--primary);
  text-align: right;
}
.form-input {
  flex: 1;
  font-size: 30rpx;
  color: var(--text);
  text-align: right;
}

/* 提交按钮 */
.submit-section {
  padding: 0 0 40rpx;
}
.submit-btn {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, #667EEA, #764BA2);
  color: #FFFFFF;
  border-radius: 50rpx;
  font-size: 34rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.4);
  border: none;
}
.submit-btn::after {
  border: none;
}
