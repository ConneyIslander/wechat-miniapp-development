.page{padding:24rpx;background:#f5f5f5;min-height:100vh}
.balance-bar{display:flex;justify-content:space-between;align-items:center;background:#fff;border-radius:16rpx;padding:28rpx 32rpx;margin-bottom:24rpx;box-shadow:0 2rpx 8rpx rgba(0,0,0,.06)}
.balance-label{font-size:28rpx;color:#666}
.balance-value{font-size:40rpx;color:#1890ff;font-weight:bold}
.add-bar{display:flex;align-items:center;background:#1890ff;color:#fff;padding:24rpx 32rpx;border-radius:16rpx;margin-bottom:32rpx;font-size:28rpx}
.add-bar text:first-child{font-size:36rpx;margin-right:12rpx}
.goals-list{display:flex;flex-direction:column;gap:20rpx}
.goal-card{display:flex;align-items:center;background:#fff;border-radius:16rpx;padding:28rpx;box-shadow:0 2rpx 8rpx rgba(0,0,0,.06)}
.goal-left{flex:1}
.goal-name{font-size:30rpx;color:#333;display:block;margin-bottom:8rpx}
.goal-amount{font-size:24rpx;color:#999;display:block;margin-bottom:6rpx}
.goal-done{font-size:24rpx;color:#52c41a;display:block}
.goal-right{width:300rpx;flex-shrink:0;text-align:right}
.goal-pct{font-size:36rpx;color:#1890ff;font-weight:bold;display:block;margin-bottom:8rpx}
.progress-bar{width:100%;height:8rpx;background:#eee;border-radius:4rpx;overflow:hidden;margin-bottom:16rpx}
.progress-fill{height:100%;background:#1890ff;border-radius:4rpx}
.goal-btns{display:flex;gap:8rpx;justify-content:flex-end}
.btn-save,.btn-withdraw,.btn-del{padding:12rpx 20rpx;background:#1890ff;color:#fff;border-radius:8rpx;font-size:26rpx;flex-shrink:0}
.btn-withdraw{background:#faad14}
.btn-del{background:#ff4d4f}
.empty{text-align:center;color:#999;padding:80rpx 0;font-size:28rpx}
.modal-mask{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.5);z-index:100;display:flex;align-items:center;justify-content:center}
.modal{background:#fff;border-radius:24rpx;padding:40rpx;width:600rpx;max-width:90vw}
.modal-title{font-size:32rpx;font-weight:bold;text-align:center;display:block;margin-bottom:32rpx}
.form-item{margin-bottom:24rpx}
.form-item text{display:block;font-size:26rpx;color:#666;margin-bottom:12rpx}
.form-item input{height:80rpx;border:2rpx solid #ddd;border-radius:12rpx;padding:0 20rpx;font-size:28rpx;background:#fafafa}
.modal-btns{display:flex;gap:20rpx;margin-top:32rpx}
.btn{padding:20rpx 0;flex:1;text-align:center;border-radius:12rpx;font-size:28rpx}
.btn.cancel{background:#f5f5f5;color:#666}
.btn.confirm{background:#1890ff;color:#fff}
.balance-tip{font-size:26rpx;color:#999;text-align:center;margin-bottom:16rpx}
